#!/bin/bash
# Fan control for Mycroft Mark II SJ-201. Writes a mode the fan daemon applies.
[ "$(id -u)" -ne 0 ] && exec sudo "$0" "$@"
OV=/run/fipfan
H=""; for d in /sys/class/hwmon/hwmon*; do [ "$(cat $d/name 2>/dev/null)" = pwmfan ] && H=$d; done
pwm2pct(){ echo $(( (255-$1)*100/255 )); }
case "$1" in
  off)  echo off  > $OV; echo "fan: OFF";;
  full) echo full > $OV; echo "fan: FULL";;
  auto) echo auto > $OV; echo "fan: AUTO (off until hot, then ramps)";;
  status|"") m=$(cat $OV 2>/dev/null || echo auto); p=$(cat $H/pwm1 2>/dev/null);
        echo "fan: mode=$m, speed $(pwm2pct ${p:-255})%, temp $(vcgencmd measure_temp | cut -d= -f2)";;
  *) if [[ "$1" =~ ^[0-9]+$ ]] && [ "$1" -le 100 ]; then echo "$1" > $OV; echo "fan: $1%";
     else echo "usage: fan [off|full|auto|status|<0-100>]"; exit 1; fi;;
esac
